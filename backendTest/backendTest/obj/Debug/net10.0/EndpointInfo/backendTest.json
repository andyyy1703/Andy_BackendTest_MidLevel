            "maxLength": 60,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "acpdEname": {
            "maxLength": 40,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "acpdSname": {
            "maxLength": 40,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "acpdEmail": {
            "maxLength": 60,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "acpdStatus": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "acpdStop": {
            "type": "boolean",
            "nullable": true
          },
          "acpdStopMemo": {
            "maxLength": 60,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "acpdLoginId": {
            "maxLength": 30,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "acpdLoginPwd": {
            "maxLength": 60,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "acpdMemo": {
            "maxLength": 600,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "acpdNowDateTime": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "acpdNowId": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "acpdUpdDateTime": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "acpdUpdId": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
